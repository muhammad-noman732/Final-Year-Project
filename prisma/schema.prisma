generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//  TENANT — One row = one university

model Tenant {
  id        String  @id @default(cuid())
  name      String // "Government College University Faisalabad"
  shortName String // "GCUF"
  slug      String  @unique // "gcuf" — used in URL / JWT
  domain    String? @unique // "fees.gcuf.edu.pk" — optional custom domain
  logoUrl   String?

  // Per-tenant branding (white-label)
  primaryColor String @default("#d4a843")
  accentColor  String @default("#0a0e1a")

  // Plan & limits — schema only, billing implemented later
  plan        Plan      @default(FREE)
  maxStudents Int       @default(500) // enforced at student creation
  isActive    Boolean   @default(true)
  trialEndsAt DateTime?

  // Extensible config without future migrations
  metadata Json? // { chatbotEnabled: false, reminderDays: [7,3,1] }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──
  users            User[]
  departments      Department[]
  programs         Program[]
  academicSessions AcademicSession[]
  students         Student[]
  feeStructures    FeeStructure[]
  feeAssignments   FeeAssignment[]
  payments         Payment[]
  emailLogs        EmailLog[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  subscription     Subscription?

  @@index([slug])
}

//  USER — All roles in one table (Admin, VC, HOD, Student, SuperAdmin)

model User {
  id       String  @id @default(cuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // tenantId is NULL only for SUPER_ADMIN — they belong to no single university

  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  avatarUrl     String?
  role          Role
  isActive      Boolean   @default(true)
  isFirstLogin  Boolean   @default(true) 
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?

  // HOD only — which department they head (NULL for all other roles)
  hodDepartmentId String?
  hodDepartment   Department? @relation("HODDepartment", fields: [hodDepartmentId], references: [id], onDelete: SetNull)

  // Relations 
  student             Student?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for performance
  @@index([email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
}

//  REFRESH TOKEN — Enables "log out all devices" & token revocation

model RefreshToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String @unique
  ipAddress  String?
  userAgent  String?
  deviceName String? 
  isRevoked Boolean   @default(false)
  revokedAt DateTime?
  expiresAt DateTime 
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRevoked])
}

//  PASSWORD RESET TOKEN — One-time, 1-hour token for forgot password

model PasswordResetToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique // SHA-256 hash — raw token is emailed
  isUsed    Boolean  @default(false)
  expiresAt DateTime // 1 hour from creation

  createdAt DateTime @default(now())

  @@index([userId])
}

//  ACADEMIC SESSION — e.g. "2024-2028" batch

model AcademicSession {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String // "2024-2028"
  startYear Int // 2024
  endYear   Int // 2028
  isCurrent Boolean @default(false)
  // Enforce ONE current session per tenant via unique partial index in migration

  students Student[]

  createdAt DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isCurrent])
}

//  DEPARTMENT — CS, Biology, Physics, Math…

model Department {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String
  code     String // "CS", "BIO", "PHY"
  isActive Boolean @default(true)

  // ── Relations ──
  hods     User[]    @relation("HODDepartment")
  programs Program[]
  students Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

//  PROGRAM — BS CS, MCS, BS SE within a department

model Program {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  // No onDelete: Cascade — can't delete a department that still has programs (RESTRICT)

  name           String // "BS Computer Science"
  code           String // "BSCS"
  degreeType     String // "BS" | "MS" | "MCS" | "PhD"
  durationYears  Int     @default(4)
  totalSemesters Int     @default(8)
  isActive       Boolean @default(true)

  // ── Relations ──
  students      Student[]
  feeStructures FeeStructure[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([departmentId])
}

// ═══════════════════════════════════════════════
//  STUDENT — Academic data extending User (role = STUDENT)
// ═══════════════════════════════════════════════

model Student {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 1-to-1 with User (the login account)
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  studentId String // "GCUF-2024-CS-0042" — auto-generated on creation
  cnic      String? // National ID — optional, used on challan

  // Academic placement
  sessionId    String
  session      AcademicSession @relation(fields: [sessionId], references: [id])
  departmentId String
  department   Department      @relation(fields: [departmentId], references: [id])
  programId    String
  program      Program         @relation(fields: [programId], references: [id])

  currentSemester  Int              @default(1)
  enrollmentStatus EnrollmentStatus @default(ACTIVE)

  // ── Denormalized fee snapshot (updated by cron + payment webhook) ──
  // Stored here to avoid expensive JOINs on every dashboard/defaulter list load
  feeStatus    FeeStatus @default(UNPAID)
  totalFeeDue  Int       @default(0) // PKR as integer — no floats
  totalFeePaid Int       @default(0)

  // Extensible future data (chatbot session ID, scholarship type, etc.)
  metadata Json?

  // ── Relations ──
  feeAssignments FeeAssignment[]
  payments       Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, studentId])
  @@index([tenantId])
  @@index([tenantId, feeStatus]) // fast defaulters query for VC dashboard
  @@index([tenantId, departmentId])
  @@index([tenantId, currentSemester])
  @@index([tenantId, enrollmentStatus])
  @@index([tenantId, departmentId, currentSemester]) // HOD filtered view
}

// ═══════════════════════════════════════════════
//  FEE STRUCTURE — Template set by Admin per program+semester
// ═══════════════════════════════════════════════

model FeeStructure {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programId String
  program   Program @relation(fields: [programId], references: [id])

  semester    Int // 1–8
  sessionYear Int // 2025 — the academic year this applies to

  // All amounts in PKR stored as integers — NEVER use Float for money
  tuitionFee      Int
  labFee          Int @default(0)
  libraryFee      Int @default(0)
  sportsFee       Int @default(0)
  registrationFee Int @default(0)
  examinationFee  Int @default(0)
  otherFee        Int @default(0)
  totalFee        Int // = sum of all above lines, enforced at application layer

  dueDate  DateTime // students must pay by this date
  lateFee  Int      @default(0) // PKR added per day after dueDate (0 = no late fee)
  isActive Boolean  @default(true)

  assignments FeeAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One fee structure per program per semester per year
  @@unique([tenantId, programId, semester, sessionYear])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

// ═══════════════════════════════════════════════
//  FEE ASSIGNMENT — "Student X owes Semester 4 fee of PKR 50,000"
// ═══════════════════════════════════════════════

model FeeAssignment {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])

  // Actual amounts — may differ from structure due to late fees or waivers
  amountDue       Int // starts equal to feeStructure.totalFee
  amountPaid      Int @default(0)
  lateFeeApplied  Int @default(0) // extra amount added by cron after due date
  discountApplied Int @default(0) // scholarship / hardship waiver deduction

  status  FeeStatus @default(UNPAID)
  dueDate DateTime // copied from FeeStructure, admins can override per-student

  // Challan for offline/bank payment
  challanNumber String? @unique // e.g. "GCUF-2025-001234" — generated on assignment
  challanUrl    String? // S3/Cloudinary URL of generated PDF

  paidAt DateTime? // when status changes to PAID

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A student can only be assigned the same fee structure once
  @@unique([studentId, feeStructureId])
  @@index([tenantId])
  @@index([studentId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, status, dueDate]) // cron: "UNPAID where dueDate < today"
}

// ═══════════════════════════════════════════════
//  PAYMENT — Every transaction. Immutable financial record.
// ═══════════════════════════════════════════════

model Payment {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  // No onDelete — financial records must NEVER be auto-deleted

  studentId       String
  student         Student       @relation(fields: [studentId], references: [id])
  feeAssignmentId String
  feeAssignment   FeeAssignment @relation(fields: [feeAssignmentId], references: [id])

  amount Int // PKR as integer — amount paid in THIS transaction
  method PaymentMethod
  status PaymentStatus @default(PENDING)

  // Stripe fields (null for non-card payments)
  stripePaymentIntentId String? @unique
  stripeResponse        Json? // full raw Stripe response — for dispute resolution

  // Bank / offline challan (admin manually verifies these)
  challanNumber  String?
  challanDueDate DateTime?
  verifiedById   String? // User.id of admin who verified
  verifiedAt     DateTime?

  // Receipt
  receiptNumber String  @unique // "GCUF-2026-00456" — auto-generated, sequential per tenant
  receiptUrl    String? // S3/Cloudinary URL of generated PDF

  // Forensics / security
  ipAddress String?
  userAgent String?

  paidAt    DateTime? // timestamp of confirmed payment
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, studentId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt]) // time-series analytics
  @@index([tenantId, status, createdAt]) // "completed payments this month"
  @@index([stripePaymentIntentId]) // fast webhook lookup
}

// ═══════════════════════════════════════════════
//  EMAIL LOG — Every email ever sent (receipts, reminders, resets)
// ═══════════════════════════════════════════════

model EmailLog {
  id       String  @id @default(cuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  // SetNull — keep email records even if tenant is deleted (compliance)

  toEmail   String
  toName    String?
  fromEmail String

  subject      String
  templateName String // "fee_receipt" | "fee_reminder" | "welcome" | "password_reset"
  templateData Json? // variables used to render — allows exact resend later

  status           EmailStatus @default(PENDING)
  provider         String      @default("resend") // "resend" | "sendgrid"
  providerId       String?     @unique // message ID from email provider
  providerResponse Json? // raw provider response

  // Optional links to source records
  paymentId String?
  userId    String?

  scheduledAt   DateTime?
  sentAt        DateTime?
  deliveredAt   DateTime? // populated from provider webhook
  failedAt      DateTime?
  failureReason String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([toEmail])
  @@index([status])
  @@index([templateName, status])
  @@index([paymentId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════
//  NOTIFICATION — In-app bell alerts
// ═══════════════════════════════════════════════

model Notification {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String // target user — no FK to keep deletes simple

  type  NotificationType
  title String
  body  String
  data  Json? // { paymentId, receiptUrl, amount } for deep-linking

  isRead  Boolean             @default(false)
  readAt  DateTime?
  channel NotificationChannel @default(IN_APP)
  sentAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead]) // bell: "unread count for user"
  @@index([tenantId, userId, isRead]) // scoped unread count
  @@index([userId, createdAt]) // notification list ordered by time
}

// ═══════════════════════════════════════════════
//  AUDIT LOG — Immutable. Append-only. Never updated or deleted.
// ═══════════════════════════════════════════════

model AuditLog {
  id       String  @id @default(cuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  // SetNull — keep audit history even after tenant deletion (compliance)

  userId    String? // who did it — nullable (system actions have no user)
  userEmail String? // snapshot at action time (user may be deleted later)
  userRole  String? // snapshot at action time

  action   String // "payment.created" | "fee.waived" | "student.suspended"
  entity   String // "Payment" | "Student" | "FeeAssignment"
  entityId String // the ID of the record affected

  oldData Json? // state BEFORE the change (null on CREATE)
  newData Json? // state AFTER the change (null on DELETE)

  ipAddress String?
  reason    String? // admin note: "Waived due to financial hardship"

  // NO updatedAt — audit logs are NEVER modified
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
  @@index([tenantId, userId])
}

// ═══════════════════════════════════════════════
//  SUBSCRIPTION — SaaS billing. Schema exists; implement billing later.
// ═══════════════════════════════════════════════

model Subscription {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  plan   Plan
  status SubscriptionStatus

  // Stripe IDs — null for FREE plan tenants
  stripeCustomerId String? @unique
  stripePriceId    String?
  stripeSubId      String? @unique

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════════════

enum Role {
  SUPER_ADMIN // You — the product company. No tenantId.
  ADMIN // University registrar. Manages everything in their tenant.
  VC // Vice Chancellor. Read-only analytics for their tenant.
  HOD // Head of Department. Sees only their department.
  STUDENT // Student. Sees only their own data.
}

enum Plan {
  FREE // Trial — capped at maxStudents (500 default)
  PRO // Paid — unlimited students + all features
  ENTERPRISE // Custom pricing + dedicated support
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum EnrollmentStatus {
  ACTIVE
  SUSPENDED // Cannot access fee payment
  GRADUATED
  WITHDRAWN
}

enum FeeStatus {
  UNPAID // Not paid yet, still within deadline
  PARTIAL // Some amount paid, balance remaining
  PAID // Fully paid
  OVERDUE // Past due date and still UNPAID/PARTIAL — set by cron
  WAIVED // Admin granted a full waiver
}

enum PaymentMethod {
  STRIPE_CARD // Online card payment via Stripe
  BANK_CHALLAN // Offline — student deposits at bank, admin verifies manually
  WAIVER // Admin granted a waiver — no actual money moved
}

enum PaymentStatus {
  PENDING // PaymentIntent created, student on Stripe checkout
  PROCESSING // Stripe is processing (card auth in progress)
  COMPLETED // payment_intent.succeeded webhook received
  FAILED // payment_intent.payment_failed
  REFUNDED // Stripe refund issued
  EXPIRED // Bank challan expired without payment
}

enum NotificationType {
  FEE_ASSIGNED // Admin assigned fee for your semester
  FEE_DUE // Reminder: due in 7 / 3 / 1 day(s)
  FEE_OVERDUE // Alert: past deadline
  PAYMENT_RECEIVED // Your payment of PKR X is confirmed
  PAYMENT_FAILED // Payment attempt failed
  CHALLAN_GENERATED // Your bank challan is ready
  DEADLINE_EXTENDED // Admin extended your fee deadline
  ACCOUNT_CREATED // Welcome — your account has been created
}

enum NotificationChannel {
  IN_APP // Shows in notification bell in dashboard
  EMAIL // Sent via Resend to user's email
}

enum EmailStatus {
  PENDING // Added to queue, not sent yet
  SENT // Accepted by provider
  DELIVERED // Provider confirmed delivery
  BOUNCED // Email address invalid or mailbox full
  FAILED // Provider returned an error
  SPAM // Marked as spam by recipient
}
